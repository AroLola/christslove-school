{
   "version": 2,
  "cleanUrls": true,
  "trailingSlash": false
  "rewrites": [
    {
      "source": "/airo-assets/uploads/(.*)",
      "destination": "/airo-assets/uploads/$1"
    },
    {
      "source": "/assets/media/(.*)",
      "destination": "/assets/media/$1"
    },
    {
      "source": "/assets/uploads/(.*)",
      "destination": "/assets/uploads/$1"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/assets/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "/media/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
