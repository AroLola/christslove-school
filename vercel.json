{
  "$schema": "https://vercel.sh",
  "version": 2,
  "builds": [
    {
      "src": "src/server/entry.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "dist/client/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "src/server/entry.ts"
    },
    {
      "src": "/(.*)",
      "dest": "src/server/entry.ts"
    }
  ]
}
