{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/assets/(.*)",
      "destination": "/dist/client/assets/$1"
    },
    {
      "source": "/media/(.*)",
      "destination": "/dist/client/media/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/client/index.html"
    }
  ]
}
